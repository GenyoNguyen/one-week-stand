# LLM API Configuration (OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# Zep Cloud
ZEP_API_KEY=

# Application
SECRET_KEY=change-me
FLASK_DEBUG=false

# Optional: load a shared env file instead of this one
# MIROFISH_ENV_FILE=/absolute/path/to/.env

# Local MCP tools
MCP_ENABLED=true
MCP_TIMEOUT_SECONDS=30
REPORT_FORCE_STRUCTURED_TABLE=true

# Optional absolute-path overrides
# MCP_DATA_DIR=/app/backend/uploads
# MCP_TABLE_SCHEMA_PATH=/app/backend/table_schema.json
